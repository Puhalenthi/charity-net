NODE_ENV=development
PORT=8080
FIREBASE_PROJECT_ID=charity-net-dev
FIREBASE_STORAGE_BUCKET=charity-net-dev.appspot.com

# Emulator suite (uncomment for local dev)
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
AI_ENABLED=true

# Notifications are in-app only (the "Alerts" feed) — no email is sent.

GOOGLE_MAPS_SERVER_KEY=
ALLOWED_ORIGINS=http://localhost:5173
JOB_SECRET=replace-with-random-string
