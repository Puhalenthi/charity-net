# ===========================================================================
# Charity Net — server configuration
#
# Copy this file to `.env` for local development.
#
# For the PRODUCTION deploy, these map to Google Cloud Run → your service →
# "Variables & Secrets". Section (1) = plain Variables, section (2) = Secrets
# you reference from Secret Manager, section (3) = local-only (Cloud Run ignores).
# ===========================================================================


# ---------------------------------------------------------------------------
# (1) CLOUD RUN — Environment variables   ← add these as plain "Variables"
# ---------------------------------------------------------------------------
# Replace YOUR_PROJECT with your Firebase / GCP project ID.
FIREBASE_PROJECT_ID=YOUR_PROJECT

# Your Storage bucket — copy the EXACT name from Firebase console → Storage
# (newer projects look like YOUR_PROJECT.firebasestorage.app; older ones
# YOUR_PROJECT.appspot.com).
FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.firebasestorage.app

# Origins allowed to call the API — comma-separated, no trailing slash.
ALLOWED_ORIGINS=https://YOUR_PROJECT.web.app,https://YOUR_PROJECT.firebaseapp.com

# Optional — these have working defaults; only add them to override:
# OPENAI_MODEL=gpt-4o          # default gpt-4o
# AI_ENABLED=true              # set false to turn off the AI photo scan


# ---------------------------------------------------------------------------
# (2) CLOUD RUN — Secrets   ← do NOT paste the values as plain variables.
#     In Cloud Run use "Secrets exposed as environment variables" and point
#     each one at the secret you already created in Secret Manager:
#
#       Env var name             Secret Manager secret
#       OPENAI_API_KEY         ← openai-key
#       GOOGLE_MAPS_SERVER_KEY ← gmaps-server-key
#       JOB_SECRET             ← cron-job-secret
#
# For LOCAL dev only, put the plain values here:
# ---------------------------------------------------------------------------
OPENAI_API_KEY=
GOOGLE_MAPS_SERVER_KEY=
JOB_SECRET=replace-with-a-long-random-string


# ---------------------------------------------------------------------------
# (3) LOCAL DEVELOPMENT ONLY   (Cloud Run ignores these — it sets NODE_ENV and
#     PORT itself and never uses the emulators)
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=8080
# Uncomment to use the Firebase emulator suite locally:
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8081
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
# FIREBASE_STORAGE_EMULATOR_HOST=127.0.0.1:9199

# Notifications are in-app only (the "Alerts" feed) — no email is sent.
