rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Item photos: owner uploads, everyone reads.
    match /items/{userId}/{itemId}/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Charity verification documents: owner uploads, only admin reads via signed URL (server).
    match /charities/{ownerUid}/verification/{file=**} {
      allow read: if request.auth != null && request.auth.token.role == 'admin';
      allow write: if request.auth != null
        && request.auth.uid == ownerUid
        && request.resource.size < 12 * 1024 * 1024;
    }

    // Charity logos: owner uploads, everyone reads.
    match /charities/{ownerUid}/logo/{file=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == ownerUid
        && request.resource.size < 4 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
